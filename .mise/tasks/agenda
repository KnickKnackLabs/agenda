#!/usr/bin/env bash
#MISE description="Read macOS Calendar data through EventKit"
#USAGE arg "[args]..." var=#true help="Command, flags, and arguments"
#USAGE example "agenda status" header="Show Calendar permission status"
#USAGE example "agenda request-access" header="Ask macOS for Calendar read access"
#USAGE example "agenda calendars --json" header="List calendars as JSON"
#USAGE example "agenda upcoming --days 14 --limit 20" header="List upcoming events"
set -euo pipefail

SCRIPT="$MISE_CONFIG_ROOT/lib/agenda.swift"

if [ ! -f "$SCRIPT" ]; then
  echo "agenda: missing Swift source: $SCRIPT" >&2
  exit 1
fi

exec "${SWIFT:-swift}" "$SCRIPT" "$@"
